# F-Droid server config (template)
#
# This repo generates a real `config.yml` during CI from GitHub Secrets so you
# never commit passwords to git. See README for setup.
#
# Docs: https://f-droid.org/en/docs/Build_Server_Reference/

repo_url: https://YOUR_GITHUB_USERNAME.github.io/YOUR_REPO_NAME/repo
repo_name: "My Private F-Droid Repo"
repo_description: "APKs mirrored from GitHub Releases and indexed by fdroidserver."

# Signing configuration (filled in during CI)
keystore: keystore.jks
repo_keyalias: fdroid
keystorepass: "__SET_IN_CI__"
keypass: "__SET_IN_CI__"

# Recommended: keep icon in your repo (optional)
# repo_icon: repo-icon.png

